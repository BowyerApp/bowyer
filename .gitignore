# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files (real keys never get committed)
.env
.env*.local

# typescript
*.tsbuildinfo
next-env.d.ts

# local sqlite database (root only — not src/lib/data)
/data/

# sdk build artifacts (rebuilt from source; downloads stay in public/downloads)
sdk/typescript/node_modules/
sdk/typescript/dist/
sdk/python/build/
sdk/python/dist/
sdk/python/*.egg-info/

# local logs
nohup.out

# local scratch
.magic-tmp/
__pycache__/
*.pyc

# server env reference (never commit)
.env.production.server

# local screenshots (never ship)
public/images/Screenshot*
public/images/IMAGE_2026*
public/images/131233211*
